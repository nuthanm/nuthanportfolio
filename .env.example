# Frontend direct submission endpoint (points to your backend API)
VITE_CONTACT_ENDPOINT=http://localhost:8787/api/contact

# Backend server
PORT=8787
FRONTEND_ORIGIN=http://localhost:5173

# Gmail SMTP (use App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Nuthan Portfolio <yourgmail@gmail.com>"
MAIL_TO=yourgmail@gmail.com

# Basic abuse protection
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=10
