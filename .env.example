# Frontend direct submission endpoint.
# For Vercel single-project deploy, keep this as /api/contact.
VITE_CONTACT_ENDPOINT=/api/contact
VITE_CONTACT_CAPTCHA_ENDPOINT=/api/contact-captcha
# Optional override for GitHub stats endpoint.
# Defaults to endpoint derived from VITE_CONTACT_ENDPOINT.
VITE_GITHUB_STATS_ENDPOINT=/api/github-stats

# Backend server
PORT=8787
FRONTEND_ORIGIN=http://localhost:5173

# Gmail SMTP (use App Password, not your normal password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Nuthan Portfolio <yourgmail@gmail.com>"
MAIL_TO=yourgmail@gmail.com
CONTACT_CAPTCHA_SECRET=replace_with_a_long_random_secret
CAPTCHA_TOKEN_TTL_MS=600000

# Basic abuse protection
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX=10
